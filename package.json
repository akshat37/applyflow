{
  "name": "applyflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "db:migrate": "cd server && npx prisma migrate dev --name init",
    "db:seed": "cd server && npx tsx prisma/seed.ts",
    "postinstall": "cd server && npx prisma generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
